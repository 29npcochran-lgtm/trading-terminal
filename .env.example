# Backend
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000
BACKEND_URL=http://localhost:5000

# Frontend
VITE_API_URL=http://localhost:5000
VITE_WS_URL=ws://localhost:5000/ws

# Data Providers
POLYGON_API_KEY=your_polygon_key_here
DATABENTO_API_KEY=your_databento_key_here
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
DXFEED_API_KEY=your_dxfeed_key_here
IB_ACCOUNT=your_ib_account_here
IB_API_KEY=your_ib_api_key_here
BINANCE_API_KEY=your_binance_key_here
BINANCE_SECRET_KEY=your_binance_secret_here
COINBASE_API_KEY=your_coinbase_key_here
COINBASE_SECRET_KEY=your_coinbase_secret_here

# Database
DATABASE_URL=sqlite:///trading.db

# Redis (for caching)
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO

# Performance
MAX_WORKERS=8
CACHE_EXPIRY=300
